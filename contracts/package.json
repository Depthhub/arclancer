{
  "name": "arclancer-contracts",
  "version": "1.0.0",
  "description": "ArcLancer Freelance Escrow Smart Contracts",
  "type": "commonjs",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
